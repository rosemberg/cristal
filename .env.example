# ─── Banco de dados ──────────────────────────────────────────────────────────
CRISTAL_DATABASE_URL=postgresql+asyncpg://cristal:cristal_dev@localhost:5432/cristal

# ─── Vertex AI / Gemini ──────────────────────────────────────────────────────
CRISTAL_VERTEX_PROJECT_ID=cloud-480917
CRISTAL_VERTEX_LOCATION=us-central1
CRISTAL_VERTEX_MODEL=gemini-2.5-flash-lite
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa-key.json

# ─── Aplicação ───────────────────────────────────────────────────────────────
CRISTAL_ENVIRONMENT=development
CRISTAL_ALLOWED_ORIGINS=["https://www.tre-pi.jus.br"]
CRISTAL_RATE_LIMIT_PER_MINUTE=10
CRISTAL_LOG_LEVEL=INFO
CRISTAL_MAX_HISTORY_MESSAGES=10
CRISTAL_MAX_CONTENT_LENGTH=5000

# ─── Cache ───────────────────────────────────────────────────────────────────
CRISTAL_CACHE_TTl_SECONDS=3600

# ─── Processamento de documentos ─────────────────────────────────────────────
CRISTAL_CHUNK_SIZE_TOKENS=1000
CRISTAL_CHUNK_OVERLAP_TOKENS=200
CRISTAL_MAX_DOCUMENT_SIZE_MB=50
